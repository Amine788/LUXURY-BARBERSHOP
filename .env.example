# Variables d'environnement — AVIATOR Barber Shop
# Copiez ce fichier en ".env.local" et renseignez vos valeurs Supabase.
# Ce fichier .env.example peut être commité. Ne commitez JAMAIS .env.local.

# URL de votre projet Supabase (ex: https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Clé publique "anon" de votre projet Supabase
# (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=

# ⚠️  La clé SERVICE_ROLE ne doit jamais être mise ici (côté client).
# Elle est utilisée uniquement pour les scripts de seed ou Edge Functions.
