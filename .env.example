# Variables d'environnement — AVIATOR Barber Shop
# Copiez ce fichier vers api/.env et remplissez les valeurs.

# --- Base de données ---
DB_HOST=127.0.0.1
DB_NAME=aviator_barbershop
DB_USER=root
DB_PASS=

# --- Sécurité JWT ---
# Générez une clé secrète avec : openssl rand -hex 64
JWT_SECRET=votre_cle_secrete_ici

# --- CORS ---
ALLOWED_ORIGIN=http://localhost:5173

# --- Email Admin & SMTP (2FA OTP) ---
ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL_NAME=AVIATOR Admin
OTP_EXPIRY=300

# Configuration SMTP (ex: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
# Utilisez un MOT DE PASSE D'APPLICATION
SMTP_PASS=votre_mot_de_passe_application_ici
